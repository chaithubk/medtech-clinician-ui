{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Dashboard",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/dashboard",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "LD_LIBRARY_PATH",
          "value": "/usr/lib/x86_64-linux-gnu:${workspaceFolder}/build/lib"
        },
        {
          "name": "QT_QPA_PLATFORM",
          "value": "offscreen"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "cmake: build",
      "miDebuggerPath": "/usr/bin/gdb"
    },
    {
      "name": "Run Tests",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/test_mqtt_client",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/build",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "preLaunchTask": "cmake: build"
    }
  ]
}